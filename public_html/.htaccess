RewriteEngine On

# ── API Proxy → Node.js backend (port 3001) ──────────────
# Requires mod_proxy and mod_proxy_http to be enabled in Apache.
# In WHM/cPanel these are usually active by default.
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^api/(.*)$ http://localhost:3001/api/$1 [P,L]

# ── SPA Fallback ──────────────────────────────────────────
# Serve index.html for all non-file, non-directory requests
# so that React Router can handle client-side navigation.
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
