# Server
PORT=3001

# Database (cPanel MySQL)
DB_HOST=localhost
DB_USER=cpanel_dbuser
DB_PASSWORD=your_db_password
DB_NAME=cpanel_dbname

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=30d

# Frontend URL (no trailing slash)
FRONTEND_URL=https://tudominio.com

# SMTP (cPanel / WHM mail server)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=correo@tudominio.com
SMTP_PASS=your_smtp_password
SMTP_FROM="PagaTú <correo@tudominio.com>"
